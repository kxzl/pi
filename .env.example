# Pi Agent — environment configuration
# Copy this file to .env and edit before running docker compose.
#   cp .env.example .env
#
# .env is gitignored — never commit it (it may contain API keys).

# Ollama server URL.
# Local:  http://localhost:11434  (default)
# Remote: http://192.168.1.x:11434
#
# For remote access, Ollama must be listening on all interfaces on the
# remote machine. Set this before starting Ollama there:
#   OLLAMA_HOST=0.0.0.0 ollama serve
OLLAMA_HOST=http://localhost:11434

# Kagi Search API key (optional — enables fast web search).
# Get one at: https://kagi.com/settings?p=api
KAGI_API_KEY=

# Host user IDs — must match the user running Docker so that files
# written inside the container aren't root-owned on the host.
# Run `id -u` and `id -g` to find your values.
# Set automatically by install.sh.
UID=1000
GID=1000
